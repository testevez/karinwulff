---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LeadForm from '@/components/LeadForm.astro';
---

<BaseLayout
  title="AVL Curious — Asheville &amp; WNC Real Estate"
  description="A working buyer's guide to Asheville and Western North Carolina — neighborhoods, hidden corners, and homes worth seeing. With Karin Wulff, Realtor® at Nexus Realty."
>
  <!-- Hero -->
  <section class="border-b border-mountain-100 bg-cream">
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
      <p class="text-xs uppercase tracking-widest text-sun-600">Asheville &middot; Western North Carolina</p>
      <h1 class="mt-3 max-w-4xl font-display text-5xl leading-[1.05] text-mountain-900 sm:text-6xl lg:text-7xl">
        Find — and <em class="text-sun-600 not-italic">win</em> — the right home in the right corner of WNC.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-mountain-600 sm:text-xl">
        Asheville and the Blue Ridge are bigger than the postcards. AVL Curious is a working
        buyer's guide to the area's neighborhoods, market data, and the homes worth seeing.
        With <strong class="text-mountain-800">Karin Wulff</strong>, Realtor® at Nexus Realty.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/contact/"
          class="inline-flex items-center rounded-md bg-mountain-900 px-6 py-3 text-base font-medium text-cream no-underline transition-colors hover:bg-sun-600"
        >
          Talk to Karin
        </a>
        <a
          href="/relocate/"
          class="inline-flex items-center rounded-md border border-mountain-200 bg-white px-6 py-3 text-base font-medium text-mountain-900 no-underline transition-colors hover:border-sun-500 hover:text-sun-600"
        >
          Explore relocating
        </a>
      </div>
    </div>
  </section>

  <!-- Brand pillars -->
  <section class="border-b border-mountain-100">
    <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <p class="text-xs uppercase tracking-widest text-sun-600">Why work with Karin</p>
      <h2 class="mt-3 max-w-3xl font-display text-3xl text-mountain-900 sm:text-4xl">
        Five things that change what your search looks like.
      </h2>

      <ul class="mt-12 grid gap-x-10 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
        <li>
          <h3 class="font-display text-xl text-mountain-900">Relentless on value</h3>
          <p class="mt-2 text-mountain-600">
            I will not let you overpay. I dig for the off-market and the undervalued, and I tell you
            what's worth this price — and what isn't.
          </p>
        </li>
        <li>
          <h3 class="font-display text-xl text-mountain-900">A WNC navigator, not just a Realtor</h3>
          <p class="mt-2 text-mountain-600">
            Asheville, Black Mountain, Weaverville, Hendersonville — they're each their own answer to a
            different question. I'll help you figure out which question is yours before we tour anything.
          </p>
        </li>
        <li>
          <h3 class="font-display text-xl text-mountain-900">Logistically capable</h3>
          <p class="mt-2 text-mountain-600">
            Financing timelines, inspections, contractor coordination, the move itself.
            Concierge-level execution, especially for relocators.
          </p>
        </li>
        <li>
          <h3 class="font-display text-xl text-mountain-900">A real local network</h3>
          <p class="mt-2 text-mountain-600">
            Lenders, real estate attorneys, photographers, stagers, contractors I trust.
            Smoother closings and, often, better rates.
          </p>
        </li>
        <li>
          <h3 class="font-display text-xl text-mountain-900">Easy to work with</h3>
          <p class="mt-2 text-mountain-600">
            No pressure. No commission-driven nudging. You'll know what I'm thinking
            and why, and you'll know where to find the best guac.
          </p>
        </li>
        <li>
          <h3 class="font-display text-xl text-mountain-900">A track record</h3>
          <p class="mt-2 text-mountain-600">
            Real closings. Real saved-money stories. Reviews from clients on
            Zillow and Homes.com.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Coming-soon callout for the tools -->
  <section class="border-b border-mountain-100 bg-mountain-900 text-cream">
    <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <p class="text-xs uppercase tracking-widest text-sun-300">Coming soon</p>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl">Three tools to help you decide.</h2>
      <ul class="mt-8 grid gap-6 sm:grid-cols-3">
        <li class="rounded-md border border-mountain-600 p-6">
          <h3 class="font-display text-xl text-cream">Where should you live in WNC?</h3>
          <p class="mt-2 text-sm text-mountain-200">
            A short matcher that recommends 2–3 neighborhoods based on lot size, commute,
            outdoor priorities, and price tier — no demographic guessing.
          </p>
        </li>
        <li class="rounded-md border border-mountain-600 p-6">
          <h3 class="font-display text-xl text-cream">Are you ready to buy?</h3>
          <p class="mt-2 text-sm text-mountain-200">
            A self-assessment with concrete next steps if you're not quite there yet —
            including the lenders I'd introduce you to.
          </p>
        </li>
        <li class="rounded-md border border-mountain-600 p-6">
          <h3 class="font-display text-xl text-cream">Is your house ready to sell?</h3>
          <p class="mt-2 text-sm text-mountain-200">
            Prep checklist + a personalized timeline. Most "not-quite-ready" gaps are things
            I can run for you.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Lead form -->
  <section class="bg-cream">
    <div class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
      <LeadForm
        variant="hero"
        source="home-bottom"
        heading="Start a low-pressure conversation."
        blurb="Tell me what you're looking for. I'll come back with neighborhoods to consider, listings worth a look, and an honest sense of whether the timing is right."
      />
    </div>
  </section>
</BaseLayout>
