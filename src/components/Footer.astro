---
// NCREC 21 NCAC 58A .0105 footer compliance:
// - Firm name (Nexus Realty) prominence ≥ Karin's name
// - Karin's NC license # — pending issue #13
// - REALTOR® mark — only if NAR member, pending issue #13
// - Equal Housing Opportunity logo + statement
// - Privacy + Accessibility links
// Until issue #13 is resolved, the license # is left as a clearly-marked TODO
// and the REALTOR® mark is on (assume NAR membership, swap if not).

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-mountain-200 bg-mountain-900 text-mountain-100">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand + brokerage -->
      <div class="lg:col-span-2">
        <p class="font-display text-xl text-cream">AVL Curious</p>
        <p class="mt-1 text-sm text-mountain-200">A working buyer's guide to Asheville &amp; Western North Carolina.</p>

        <div class="mt-6 space-y-1 text-sm">
          <p>
            <span class="font-semibold">Nexus Realty</span> · 100 Julian Shoals Drive, Arden, NC 28704
          </p>
          <p>Office: <a href="tel:+18285852188" class="text-mountain-100 underline-offset-2 hover:text-sun-300">(828) 585-2188</a></p>
          <p>
            Karin Wulff, Realtor<sup>®</sup>
            <span class="text-mountain-400"> · NC License #</span><span class="text-mountain-400 italic">[pending]</span>
          </p>
          <p>
            Direct: <a href="tel:+12017256428" class="text-mountain-100 underline-offset-2 hover:text-sun-300">(201) 725-6428</a>
            · <a href="mailto:karin@fuzzywolfsales.com" class="text-mountain-100 underline-offset-2 hover:text-sun-300">karin@fuzzywolfsales.com</a>
          </p>
        </div>
      </div>

      <!-- Site links -->
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-mountain-400">Site</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/buy/" class="text-mountain-100 hover:text-sun-300">Buy</a></li>
          <li><a href="/sell/" class="text-mountain-100 hover:text-sun-300">Sell</a></li>
          <li><a href="/relocate/" class="text-mountain-100 hover:text-sun-300">Relocate</a></li>
          <li><a href="/about/" class="text-mountain-100 hover:text-sun-300">About Karin</a></li>
          <li><a href="/contact/" class="text-mountain-100 hover:text-sun-300">Contact</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-mountain-400">Legal</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/privacy/" class="text-mountain-100 hover:text-sun-300">Privacy Policy</a></li>
          <li><a href="/accessibility/" class="text-mountain-100 hover:text-sun-300">Accessibility</a></li>
          <li>
            <a
              href="https://www.ncrec.gov/Forms/WWREA/WWREADisclosureForm.pdf"
              target="_blank"
              rel="noopener"
              class="text-mountain-100 hover:text-sun-300"
            >
              NC Working With Real Estate Agents (PDF)
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Equal Housing + closing -->
    <div class="mt-10 flex flex-col items-start gap-4 border-t border-mountain-600 pt-6 text-xs text-mountain-200 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <!-- Equal Housing Opportunity inline mark (HUD logo to be swapped in) -->
        <span aria-hidden="true" class="inline-flex h-7 w-7 items-center justify-center rounded-sm border border-mountain-200 text-[10px] font-semibold uppercase">EHO</span>
        <span>Equal Housing Opportunity. We conduct all brokerage activities without respect to race, color, religion, sex, national origin, disability, or familial status.</span>
      </div>
      <p>&copy; {year} Karin Wulff at Nexus Realty. AVL Curious is a marketing brand operated by the agent.</p>
    </div>
  </div>
</footer>
