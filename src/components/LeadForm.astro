---
interface Props {
  variant?: 'hero' | 'inline' | 'full';
  heading?: string;
  blurb?: string;
  source?: string;
}

const {
  variant = 'inline',
  heading = "Tell me what you're looking for.",
  blurb = "I'll help you find the right neighborhood and the right house, at the right price.",
  source = 'unknown',
} = Astro.props;

// Form endpoint configurable via env. Currently wired for Web3Forms (#6).
// To activate: sign up at web3forms.com with karin@fuzzywolfsales.com, get the
// access key, set PUBLIC_FORM_ACCESS_KEY in the build environment.
// Until then submissions are dropped (placeholder key).
const formEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT ?? 'https://api.web3forms.com/submit';
const accessKey = import.meta.env.PUBLIC_FORM_ACCESS_KEY ?? 'PLACEHOLDER_ACCESS_KEY';
const bccEmail = import.meta.env.PUBLIC_FORM_BCC ?? 'tootast@gmail.com';
---

<section
  class:list={[
    'rounded-lg border border-mountain-200 bg-white p-6 shadow-sm sm:p-8',
    variant === 'hero' && 'ring-1 ring-sun-300/40',
  ]}
  aria-labelledby={`leadform-${variant}-heading`}
>
  <h2 id={`leadform-${variant}-heading`} class="font-display text-2xl text-mountain-900 sm:text-3xl">
    {heading}
  </h2>
  <p class="mt-2 max-w-prose text-mountain-600">{blurb}</p>

  <form
    method="POST"
    action={formEndpoint}
    class="mt-6 space-y-5"
    data-leadform-source={source}
    novalidate
  >
    <!-- Web3Forms wiring -->
    <input type="hidden" name="access_key" value={accessKey} />
    <input type="hidden" name="subject" value={`[avlcurious.com] New lead — ${source}`} />
    <input type="hidden" name="from_name" value="AVL Curious lead form" />
    <input type="hidden" name="bcc" value={bccEmail} />
    <!-- Tracking -->
    <input type="hidden" name="form_source" value={source} />
    <!-- Honeypot — bots fill this; humans don't -->
    <input type="text" name="botfield" tabindex="-1" autocomplete="off" class="absolute -left-[5000px]" aria-hidden="true" />

    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block text-sm">
        <span class="text-mountain-800 font-medium">Name <span class="text-sun-600" aria-hidden="true">*</span></span>
        <input type="text" name="name" required autocomplete="name"
          class="mt-1 block w-full rounded border border-mountain-200 bg-white px-3 py-2 focus:border-sun-500" />
      </label>

      <label class="block text-sm">
        <span class="text-mountain-800 font-medium">Email <span class="text-sun-600" aria-hidden="true">*</span></span>
        <input type="email" name="email" required autocomplete="email"
          class="mt-1 block w-full rounded border border-mountain-200 bg-white px-3 py-2 focus:border-sun-500" />
      </label>

      <label class="block text-sm sm:col-span-2">
        <span class="text-mountain-800 font-medium">Phone <span class="text-sun-600" aria-hidden="true">*</span></span>
        <input type="tel" name="phone" required autocomplete="tel" pattern="[0-9\-\+\(\)\s\.]{10,}"
          class="mt-1 block w-full rounded border border-mountain-200 bg-white px-3 py-2 focus:border-sun-500" />
      </label>
    </div>

    <fieldset class="space-y-2">
      <legend class="text-sm font-medium text-mountain-800">What are you up to?</legend>
      <div class="grid gap-1 sm:grid-cols-2">
        {['Buying', 'Selling', 'Both — buy + sell', 'Just exploring'].map((label) => (
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="intent" value={label} required class="h-4 w-4 accent-sun-500" />
            <span>{label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="space-y-2">
      <legend class="text-sm font-medium text-mountain-800">Budget range</legend>
      <div class="grid gap-1 sm:grid-cols-2">
        {[
          'Under $500K',
          '$500K – $750K',
          '$750K – $1M',
          '$1M – $2M',
          '$2M+',
          'Just exploring',
        ].map((label) => (
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="budget" value={label} required class="h-4 w-4 accent-sun-500" />
            <span>{label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="space-y-2">
      <legend class="text-sm font-medium text-mountain-800">Timeline</legend>
      <div class="grid gap-1 sm:grid-cols-2">
        {[
          'Less than 3 months',
          '3 – 6 months',
          '6 – 12 months',
          'Over 12 months / flexible',
        ].map((label) => (
          <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="timeline" value={label} required class="h-4 w-4 accent-sun-500" />
            <span>{label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <label class="block text-sm">
      <span class="text-mountain-800 font-medium">Anything else?</span>
      <textarea name="message" rows="4"
        class="mt-1 block w-full rounded border border-mountain-200 bg-white px-3 py-2 focus:border-sun-500"
      ></textarea>
    </label>

    <!-- TCPA opt-in (required by the plan's compliance section) -->
    <label class="flex items-start gap-2 text-xs text-mountain-600">
      <input type="checkbox" name="contact_consent" required class="mt-0.5 h-4 w-4 accent-sun-500" />
      <span>
        I agree Karin Wulff may contact me by phone, email, or text at the contact information provided. Message and data rates may apply.
      </span>
    </label>

    <p class="text-xs text-mountain-400">
      When we connect, I'll share the NC <em>Working With Real Estate Agents</em> disclosure
      — it explains how agents represent buyers and sellers in North Carolina.
    </p>

    <button
      type="submit"
      style="color: #ffffff;"
      class="inline-flex items-center justify-center rounded-md bg-mountain-900 px-5 py-3 text-sm font-semibold transition-colors hover:bg-sun-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sun-500"
    >
      Send to Karin
    </button>
  </form>
</section>

<script is:inline>
  // Fire a `generate_lead` GA4 event on submission. Runs before the form
  // actually POSTs (Web3Forms redirects after success), so we capture the
  // intent regardless of network outcome. Includes the form source surface
  // (home-bottom, contact-page, etc.) and the budget/timeline tier so you
  // can segment lead quality in GA4.
  document.querySelectorAll('form[data-leadform-source]').forEach(function (form) {
    form.addEventListener('submit', function () {
      if (!window.gtag) return;
      var fd = new FormData(form);
      window.gtag('event', 'generate_lead', {
        form_source: form.getAttribute('data-leadform-source'),
        budget: fd.get('budget') || '',
        timeline: fd.get('timeline') || '',
        intent: fd.get('intent') || ''
      });
    });
  });
</script>
