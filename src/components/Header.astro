---
const { pathname } = Astro.url;

const links = [
  { href: '/buy/', label: 'Buy' },
  { href: '/sell/', label: 'Sell' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="border-b border-mountain-100 bg-cream">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-baseline gap-2 no-underline" aria-label="AVL Curious — home">
      <span class="font-display text-2xl font-medium tracking-tight text-mountain-900">AVL Curious</span>
      <span class="hidden text-xs uppercase tracking-widest text-mountain-400 sm:inline">
        Asheville Real Estate
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-2 sm:gap-6">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'rounded px-2 py-1 text-sm no-underline transition-colors sm:text-base',
                isActive(href)
                  ? 'text-mountain-900 underline decoration-2 underline-offset-4'
                  : 'text-mountain-600 hover:text-sun-600',
              ]}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
