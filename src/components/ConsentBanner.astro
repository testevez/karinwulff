---
// Lightweight consent banner. Appears once per browser until the user makes
// a choice; the choice is persisted in localStorage under "avlc-consent"
// (values: "granted" or "denied"). Coordinates with Analytics.astro via the
// Consent Mode v2 update API.
---

<div
  id="avlc-consent-banner"
  hidden
  class="fixed bottom-4 left-4 right-4 z-50 rounded-lg border border-mountain-200 bg-white p-4 shadow-lg sm:left-auto sm:right-4 sm:max-w-md"
  role="region"
  aria-label="Cookie consent"
>
  <p class="text-sm text-mountain-700">
    We use Google Analytics to understand which pages and topics readers find
    useful, so we can improve the site. Cookies only set after you accept.
    See <a href="/privacy/" class="underline">Privacy Policy</a>.
  </p>
  <div class="mt-3 flex flex-wrap gap-2">
    <button
      type="button"
      data-consent="granted"
      style="color: #ffffff;"
      class="inline-flex items-center rounded-md bg-mountain-900 px-4 py-2 text-sm font-semibold transition-colors hover:bg-sun-600"
    >
      Accept
    </button>
    <button
      type="button"
      data-consent="denied"
      class="inline-flex items-center rounded-md border border-mountain-200 bg-white px-4 py-2 text-sm font-medium text-mountain-700 transition-colors hover:border-mountain-400"
    >
      Decline
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = 'avlc-consent';
    var banner = document.getElementById('avlc-consent-banner');
    if (!banner) return;

    var stored = null;
    try { stored = localStorage.getItem(KEY); } catch (_) {}

    if (!stored) {
      // small delay so the banner doesn't compete with the hero LCP
      setTimeout(function () { banner.hidden = false; }, 800);
    }

    banner.querySelectorAll('button[data-consent]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var val = btn.getAttribute('data-consent');
        try { localStorage.setItem(KEY, val); } catch (_) {}
        if (window.gtag) {
          window.gtag('consent', 'update', {
            analytics_storage: val === 'granted' ? 'granted' : 'denied'
          });
        }
        banner.hidden = true;
      });
    });
  })();
</script>
